# Google Gemini API Key (required for AI analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token (required to prevent anonymous API limits)
GITHUB_TOKEN=your_github_pat_here

# NVD API Key (optional — increases rate limit from 5 to 50 req/30s)
NVD_API_KEY=your_nvd_api_key_here

# GitHub Webhook Secret (optional — verifies payloads from GitHub webhooks)
# Setup: GitHub repo → Settings → Webhooks → Payload URL = <backend>/webhook/github
# Events to subscribe: Pull requests + Issue comments
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Telegram notifications (optional)
# Get BOT_TOKEN from @BotFather, CHAT_ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

